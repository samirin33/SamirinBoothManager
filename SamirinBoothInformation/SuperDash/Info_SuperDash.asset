      day: 22
  - updateName: ver1.0.2
    updateDescription: "\u30D7\u30ED\u30B0\u30E9\u30E0\u306E\u4E0D\u8981\u306A\u30B3\u30FC\u30C9\u3092\u524A\u9664\u30FBSuperDash_Plus\u30D1\u30C3\u30B1\u30FC\u30B8\u306BSuperDash\u672C\u4F53\u3082\u542B\u307E\u308C\u308B\u3088\u3046\u306B\u5909\u66F4"
    updateDate:
      year: 2025
      month: 5
      day: 23
  - updateName: ver1.0.3
    updateDescription: "\u30BB\u30C3\u30C8\u30A2\u30C3\u30D7\u753B\u9762\u306B\u3050\u308B\u3050\u308B\u30A8\u30D5\u30A7\u30AF\u30C8\u306E\u524D\u9762\u79FB\u52D5(\u811A\u3088\u308A\u624B\u524D\u306B\u8868\u793A\u3059\u308B\u305F\u3081\u306E\u79FB\u52D5)\u306E\u8DDD\u96E2\u3092\u8A2D\u5B9A\u3067\u304D\u308B\u30B9\u30E9\u30A4\u30C0\u30FC\u3092\u8FFD\u52A0\n\u4E00\u90E8\u306E\u30A2\u30CB\u30E1\u30FC\u30B7\u30E7\u30F3\u306E\u4E0D\u5177\u5408\u304B\u3089\u306E\u90FD\u5408\u4E0A\u306B\u3088\u308A\u300C\u3050\u308B\u3050\u308B\u6642\u306B\u8DB3\u306E\u30A2\u30CB\u30E1\u30FC\u30B7\u30E7\u30F3\u3092\u7121\u52B9\u5316\u300D\u306E\u8A2D\u5B9A\u3092\u5EC3\u6B62\n\u4E00\u5B9A\u6761\u4EF6\u4E0B\u3067\u30C0\u30C3\u30B7\u30E5\u6642\u306E\u7159\u306E\u30A8\u30D5\u30A7\u30AF\u30C8\u304C\u60F3\u5B9A\u3088\u308A\u5927\u304D\u304F\u8868\u793A\u3055\u308C\u3066\u3057\u307E\u3046\u554F\u984C\u3092\u4FEE\u6B63\nVRCEmote\u306B\u3088\u308B\u30A8\u30E2\u30FC\u30C8\u518D\u751F\u4E2D\u306B\u30C0\u30C3\u30B7\u30E5\u304C\u3067\u304D\u306A\u304F\u306A\u308A\u307E\u3057\u305F\n\u5404\u30BF\u30FC\u30DC\u306E\u6700\u5927\u52A0\u901F\u5024\u3092\u5897\u3084\u3057\u307E\u3057\u305F\n\u58C1\u30A2\u30AF\u30B7\u30E7\u30F3\u3092\u884C\u3046\u305F\u3081\u306E\u5224\u5B9A\u3092\u5927\u304D\u304F\u3057\u307E\u3057\u305F"
    updateDate:
