  - updateName: ver1.1.2
    updateDescription: "\u300C\u307F\u307F\u8D85\u62E1\u5F35\u300D\u3068\u4F75\u7528\u3057\u305F\u969B\u306B\u3001\u5F53\u305F\u308A\u5224\u5B9A\u7528\u306E\u30D1\u30FC\u30C6\u30A3\u30AF\u30EB\u304C\u8868\u793A\u3055\u308C\u3066\u3057\u307E\u3046\u4E8B\u304C\u3042\u308B\u554F\u984C\u3092\u4FEE\u6B63"
