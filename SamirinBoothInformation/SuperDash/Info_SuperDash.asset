  - updateName: ver1.1.3
    updateDescription: "\u52B9\u679C\u97F3\u518D\u751F\u6642\u306B\u30CE\u30A4\u30BA\u304C\u8D70\u308A\u3001\u30CE\u30A4\u30BA\u304C\u30A2\u30D0\u30BF\u30FC\u304B\u3089\u9060\u3044\u5834\u6240\u3067\u3082\u805E\u3053\u3048\u308B\u3053\u3068\u304C\u3042\u308B\u554F\u984C\u3092\u4FEE\u6B63\n\u3050\u308B\u3050\u308B\u30BC\u30F3\u30DE\u30A4\u306E\u30C1\u30E3\u30FC\u30B8\u6642\u9593\u3092\u77ED\u7E2E\u3057\u3001\u30C0\u30C3\u30B7\u30E5\u901F\u5EA6\u3092\u4E0A\u6607\u3055\u305B\u307E\u3057\u305F\u3002"
    updateDate:
