      month: 5
      day: 25
  - updateName: ver1.1.0
    updateDescription: "\u65B0\u30A2\u30AF\u30B7\u30E7\u30F3\u300C\u3050\u308B\u3050\u308B\u30BC\u30F3\u30DE\u30A4\u300D\u8FFD\u52A0\uFF01\u624B\u3092\u306B\u304E\u3063\u3066\u5F8C\u308D\u306B\u4E0B\u304C\u308B\u3068\u30BC\u30F3\u30DE\u30A4\u3092\u5DFB\u304D\u3001\u305D\u306E\u5F8C\u306E\u30B8\u30E3\u30F3\u30D7\u3067\u9AD8\u901F\u6ED1\u7A7A\u304C\u3067\u304D\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\uFF01\n\u3057\u3083\u304C\u307F\u30B8\u30E3\u30F3\u30D7\u3092\u884C\u3046\u969B\u306B\u3001\u767A\u52D5\u6761\u4EF6\u3068\u3057\u3066\u624B\u3092\u63E1\u308B\u52D5\u4F5C\u3092\u8FFD\u52A0\u3057\u307E\u3057\u305F\n\u30BB\u30C3\u30C8\u30A2\u30C3\u30D7\u6642\u306E\u3050\u308B\u3050\u308B\u30A8\u30D5\u30A7\u30AF\u30C8\u306E\u30B9\u30B1\u30FC\u30EB\u306E\u81EA\u52D5\u8ABF\u6574\u3092\u884C\u3046\u969B\u3001\u30A2\u30D0\u30BF\u30FC\u306E\u8DB3\u306E\u30DC\u30FC\u30F3\u4F4D\u7F6E\u304B\u3089\u8ABF\u6574\u3055\u308C\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3057\u305F\n\u58C1\u30A2\u30AF\u30B7\u30E7\u30F3\u306E\u5224\u5B9A\u3092\u518D\u8ABF\u6574\u3057\u307E\u3057\u305F\n\u4E00\u90E8\u306E\u30A8\u30D5\u30A7\u30AF\u30C8\u306E\u8ABF\u6574\u3092\u884C\u3044\u307E\u3057\u305F"
